{
  "name": "BarStock",
  "short_name": "BarStock",
  "description": "Tablet stock control and checkout for Nexio bar operations.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "any",
  "theme_color": "#0f766e",
  "background_color": "#f8fafc",
  "icons": [
    {
      "src": "/icons/barstock-icon.svg",
      "sizes": "any",
