# Copy to .env and edit for your environment.

# Base URL the browser uses to reach the backend API. Must be an address
# your browser can actually resolve and connect to — not necessarily the
# same host/port the backend process binds to. See README.md "Environment
# variables & CORS" for examples (local, Docker, cloud IDE, remote VM).
VITE_API_BASE=http://127.0.0.1:8000
