# Copy to .env and edit for your environment.

# --- App ---
APP_ENV=development
APP_NAME=barstock
APP_VERSION=0.1.0
LOG_LEVEL=INFO
# 32+ char random string; rotate to invalidate all live tokens
SECRET_KEY=change-me-in-prod-this-is-a-dev-key-1234567890
# JWT
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=720  # 12 hours, suits a single counter shift
# bcrypt cost (4..31; 12 is a good dev default)
BCRYPT_ROUNDS=12

# --- Database ---
# Async DSN — used by both the app and Alembic (async template)
DATABASE_URL=postgresql+asyncpg://barstock:barstock@127.0.0.1:5432/barstock

# --- CORS (JSON array; empty = no CORS) ---
CORS_ALLOW_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173","http://127.0.0.1:5174","http://localhost:5174","http://127.0.0.1:5175","http://localhost:5175"]
