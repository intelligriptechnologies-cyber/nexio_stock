    {
      "id": "file:app/api/auth.py",
      "type": "file",
      "name": "auth.py",
      "filePath": "app/api/auth.py",
      "summary": "Authentication router providing separate login endpoints for superadmins and shop staff; shares a private `_authenticate` helper that verifies role, shop scope, active status and password before minting a JWT access token.",
      "tags": ["authentication", "api-handler", "security", "entry-point"],
      "complexity": "complex",
      "languageNotes": "Distinguishes superadmin vs shop-scoped login flows behind one shared credential-checking helper to avoid duplicating the password/role/active checks."
    },
    {
      "id": "file:app/api/deps.py",
      "type": "file",
      "name": "deps.py",
      "filePath": "app/api/deps.py",
      "summary": "Core FastAPI dependency module: builds DB sessions, resolves the current user from a bearer JWT (401 on missing/invalid/inactive), and exposes `require_role`/`require_shop_scope` guard factories for server-side role enforcement.",
      "tags": ["middleware", "authentication", "authorization", "dependency-injection"],
      "complexity": "complex",
      "languageNotes": "require_role is a dependency factory returning a closure (_guard) so routes can declare Depends(require_role(Role.A, Role.B)) with 403 detail listing allowed roles."
    },
