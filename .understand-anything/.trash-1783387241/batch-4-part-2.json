  "nodes": [
    {
      "id": "file:app/services/checkout.py",
      "type": "file",
      "name": "checkout.py",
      "filePath": "app/services/checkout.py",
      "summary": "Core checkout engine: resolves cart barcodes to products, computes current stock via received-minus-sold subqueries, and atomically finalizes a sale under a row lock (FOR UPDATE) with idempotency-key replay and payment-split validation.",
      "tags": ["transaction", "concurrency", "idempotency", "checkout", "business-logic"],
      "complexity": "complex",
      "languageNotes": "Uses SQLAlchemy `with_for_update()` row locks on Product and Shop rows plus a UNION ALL subquery pattern to compute net stock, making this one of the most concurrency-sensitive files in the codebase."
    },
    {
      "id": "file:app/services/eod.py",
      "type": "file",
      "name": "eod.py",
      "filePath": "app/services/eod.py",
      "summary": "End-of-day reconciliation service: enforces once-per-business-day sign-off, aggregates a day's invoice and payment totals excluding voids/reversals, and lists sign-off history and pending post-EOD void requests.",
      "tags": ["eod", "reconciliation", "reporting", "aggregation"],
      "complexity": "moderate"
    },
    {
      "id": "file:app/services/invoice_pdf.py",
      "type": "file",
      "name": "invoice_pdf.py",
      "filePath": "app/services/invoice_pdf.py",
      "summary": "Renders a finalized invoice as a PDF using ReportLab, building a document story with header, line-item table, payment table, and totals/footer.",
      "tags": ["pdf-generation", "invoicing", "reporting", "reportlab"],
      "complexity": "moderate"
    },
    {
      "id": "file:app/services/voids.py",
      "type": "file",
      "name": "voids.py",
      "filePath": "app/services/voids.py",
      "summary": "Two-tier void/reversal state machine: same-day direct voids apply immediately, while post-EOD voids require an owner request/approve/reject cycle where approval creates a signed reversal invoice under a row lock.",
      "tags": ["void", "reversal", "state-machine", "concurrency", "business-logic"],
      "complexity": "complex",
      "languageNotes": "approve_post_eod_void row-locks the Shop and constructs a full mirrored reversal Invoice (negated lines and payments), making it the most state-sensitive function in this file."
    },
