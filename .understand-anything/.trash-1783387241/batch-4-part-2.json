    {
      "id": "function:app/services/checkout.py:_current_stock_for",
      "type": "function",
      "name": "_current_stock_for",
      "filePath": "app/services/checkout.py",
      "lineRange": [140, 224],
      "summary": "Computes current on-hand stock per product via a UNION of received-quantity and sold-quantity subqueries (received lots minus quantities on finalized invoice lines).",
      "tags": ["sql", "inventory", "aggregation"],
      "complexity": "complex",
      "languageNotes": "Builds a hand-rolled outer-join + UNION ALL SQLAlchemy Core query to net received lot quantities against sold invoice quantities per product, including products with sales but no recorded receipts."
    },
    {
      "id": "function:app/services/checkout.py:finalize_checkout",
      "type": "function",
      "name": "finalize_checkout",
      "filePath": "app/services/checkout.py",
      "lineRange": [227, 399],
      "summary": "Atomically finalizes a sale: validates the idempotency key, signed-off-day state, and payment totals; replays an existing idempotency key if one is found; row-locks the affected products and shop (FOR UPDATE); verifies sufficient stock; and creates the Invoice, InvoiceLine, Payment, and IdempotencyKey rows within one transaction.",
      "tags": ["transaction", "concurrency", "idempotency", "checkout", "business-logic"],
      "complexity": "complex",
      "languageNotes": "The single most sensitive function in the codebase: combines idempotent replay, multi-row FOR UPDATE locking, and Decimal-precise money math in one 170+ line transaction."
    },
