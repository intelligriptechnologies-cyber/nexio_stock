    {
      "id": "function:app/api/products.py:import_products_csv",
      "type": "function",
      "name": "import_products_csv",
      "filePath": "app/api/products.py",
      "lineRange": [205, 349],
      "summary": "Bulk-imports products from an uploaded CSV file: decodes with UTF-8/UTF-8-BOM fallback, validates required headers, then for each row parses and validates barcode/brand/size/price/threshold, inserts the product, and on a per-row unique-constraint violation rolls back just that row's savepoint-like flush and records a structured ProductImportError instead of aborting the whole import.",
      "tags": ["csv-import", "bulk-operation", "error-handling", "validation"],
      "complexity": "complex",
      "languageNotes": "Row-level flush+rollback isolation lets one bad row fail without discarding previously-validated rows in the same request -- a manual poor-man's savepoint pattern since SQLAlchemy async doesn't expose nested transactions as simply as sync."
    },
