      "id": "file:app/services/low_stock.py",
      "type": "file",
      "name": "low_stock.py",
      "filePath": "app/services/low_stock.py",
      "summary": "Computes low-stock alerts per shop by deriving current stock as received-minus-sold via a UNION ALL of two aggregated subqueries, then comparing against each product's effective threshold (per-product override falling back to shop default) and returning rows sorted by most urgent first.",
      "tags": ["service", "inventory", "reporting", "aggregation"],
      "complexity": "complex",
      "languageNotes": "Uses a full-outer-join-style UNION ALL of two subqueries (received via LotLine, sold via InvoiceLine filtered to counted statuses) to compute stock from two independent tables without a stock ledger table -- a non-trivial derived-stock computation."
    },
    {
      "id": "function:app/services/low_stock.py:_stock_per_product",
      "type": "function",
      "name": "_stock_per_product",
      "filePath": "app/services/low_stock.py",
      "lineRange": [47, 118],
      "summary": "Builds and executes a combined received/sold aggregation query (via UNION ALL of two subqueries with an outer join fallback) to derive net current stock per active product in a shop.",
      "tags": ["query", "aggregation", "inventory"],
      "complexity": "complex"
    },
    {
      "id": "function:app/services/low_stock.py:compute_low_stock",
      "type": "function",
      "name": "compute_low_stock",
      "filePath": "app/services/low_stock.py",
      "lineRange": [121, 170],
      "summary": "Loads all active products for a shop, computes their derived stock, compares against the effective (per-product or shop-default) low-stock threshold, and returns matching rows sorted by most urgent (lowest stock relative to threshold) first.",
