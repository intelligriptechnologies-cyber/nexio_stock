      "filePath": "app/services/checkout.py",
      "lineRange": [77, 79],
      "summary": "Return wrapper from finalize_checkout carrying the resulting invoice and a flag indicating whether the call was an idempotent replay.",
      "tags": ["data-model", "dto", "idempotency"],
      "complexity": "simple"
    },
    {
      "id": "function:app/services/checkout.py:_is_today_signed_off",
      "type": "function",
      "name": "_is_today_signed_off",
      "filePath": "app/services/checkout.py",
      "lineRange": [98, 110],
      "summary": "Checks whether the shop's business day has already been signed off for end-of-day, blocking further checkouts if so.",
      "tags": ["validation", "eod", "helper"],
      "complexity": "simple"
    },
    {
      "id": "function:app/services/checkout.py:_resolve_products_for_cart",
      "type": "function",
      "name": "_resolve_products_for_cart",
      "filePath": "app/services/checkout.py",
      "lineRange": [113, 137],
      "summary": "Resolves cart barcodes to active Product records for the shop, raising CheckoutError for any barcode that cannot be matched.",
      "tags": ["validation", "lookup", "helper"],
      "complexity": "moderate"
    },
    {
      "id": "function:app/services/checkout.py:_current_stock_for",
      "type": "function",
      "name": "_current_stock_for",
      "filePath": "app/services/checkout.py",
      "lineRange": [140, 224],
      "summary": "Computes live stock per product as received lot quantity minus finalized invoice quantity, using unioned aggregate subqueries so partial-only data (received-only or sold-only) is still counted.",
      "tags": ["query", "inventory", "aggregation", "helper"],
      "complexity": "complex",
      "languageNotes": "Combines two GROUP BY subqueries with an outer join plus a UNION ALL branch to cover products present in only one side of the join."
    },
    {
      "id": "function:app/services/checkout.py:finalize_checkout",
      "type": "function",
      "name": "finalize_checkout",
      "filePath": "app/services/checkout.py",
      "lineRange": [227, 399],
      "summary": "End-to-end checkout finalization: validates idempotency key, cart totals, and EOD status, locks affected products and the shop row, verifies sufficient stock, then persists the Invoice, InvoiceLines, Payments, and an idempotency record in one transaction.",
      "tags": ["transaction", "checkout", "concurrency-control", "entry-point"],
      "complexity": "complex",
      "languageNotes": "Locks Product and Shop rows with with_for_update() to serialize concurrent checkouts against the same stock and invoice numbering sequence."
    },
