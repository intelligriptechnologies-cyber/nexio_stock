      "name": "invoice_pdf.py",
      "filePath": "app/services/invoice_pdf.py",
      "summary": "Renders a finalized invoice as a printable PDF receipt (shop header, line items, payment breakdown) using ReportLab.",
      "tags": ["service", "pdf-generation", "reporting"],
      "complexity": "moderate",
      "languageNotes": "Builds the document as a ReportLab 'story' of flowables (Paragraph, Table, Spacer) rendered into an in-memory BytesIO buffer."
    },
