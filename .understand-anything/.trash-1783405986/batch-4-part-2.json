    {
      "id": "file:app/services/voids.py",
      "type": "file",
      "name": "voids.py",
      "filePath": "app/services/voids.py",
      "summary": "Service handling invoice voiding: immediate same-day voids, and a request/approve/reject workflow for post-EOD voids that require owner sign-off and create reversal entries.",
      "tags": ["service", "business-logic", "transaction", "approval-workflow"],
      "complexity": "complex",
      "languageNotes": "Post-EOD voids are modeled as a two-step workflow (request then owner approval) since the original invoice cannot simply be deleted after end-of-day sign-off; approval creates a reversal invoice/lines rather than mutating the original."
    },
