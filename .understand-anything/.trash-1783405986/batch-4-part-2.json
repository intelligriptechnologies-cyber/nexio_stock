      "lineRange": [149, 230],
      "summary": "Owner-approves a pending post-EOD void: locks the shop row, creates a reversal Invoice with negated InvoiceLines and Payments, and marks the original invoice voided.",
      "tags": ["approval-workflow", "transaction", "concurrency-control", "entry-point"],
      "complexity": "complex"
    },
