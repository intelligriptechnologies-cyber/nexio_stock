{
  "nodes": [
    {
      "id": "file:app/services/checkout.py",
      "type": "file",
      "name": "checkout.py",
      "filePath": "app/services/checkout.py",
      "summary": "Core checkout service that validates cart lines against live stock, enforces idempotency and EOD sign-off rules, and finalizes an invoice with payments inside a single transaction.",
      "tags": ["service", "transaction", "inventory", "idempotency", "business-logic"],
      "complexity": "complex",
      "languageNotes": "Uses row-level locking (with_for_update) and correlated subqueries to compute live stock (received minus sold) before allowing checkout, protecting against overselling under concurrency."
    },
    {
      "id": "class:app/services/checkout.py:CheckoutError",
      "type": "class",
      "name": "CheckoutError",
      "filePath": "app/services/checkout.py",
      "lineRange": [49, 59],
      "summary": "Domain exception raised for any checkout validation failure (bad idempotency key, insufficient stock, EOD already signed off, payment mismatch).",
      "tags": ["exception", "validation", "error-handling"],
      "complexity": "simple"
    },
    {
      "id": "class:app/services/checkout.py:CartLine",
      "type": "class",
      "name": "CartLine",
      "filePath": "app/services/checkout.py",
      "lineRange": [62, 66],
      "summary": "Simple data holder representing a requested cart line (barcode and quantity) passed into the checkout service.",
      "tags": ["data-model", "dto"],
      "complexity": "simple"
    },
    {
      "id": "class:app/services/checkout.py:PaymentLine",
      "type": "class",
